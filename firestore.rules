rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net: default deny all undefined paths
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Rules for enterprises collection
    match /enterprises/{enterpriseId} {
      allow read, write: if true;
    }

    // 4. Rules for users collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // 5. Rules for settings collection
    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
