{
  "entities": {
    "enterprise": {
      "title": "Enterprise",
      "description": "A chamber member enterprise containing info and cotisation records",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "memberNo": { "type": "string" },
        "statutMembre": { "type": "string" },
        "dateAdhesion": { "type": "string" },
        "raisonSociale": { "type": "string" },
        "pays": { "type": "string" },
        "ville": { "type": "string" },
        "secteur": { "type": "string" },
        "effectif": { "type": "string" },
        "formeJuridique": { "type": "string" },
        "numRC": { "type": "string" },
        "ninea": { "type": "string" },
        "dateCreation": { "type": "string" },
        "adresse": { "type": "string" },
        "telephone": { "type": "string" },
        "email": { "type": "string" },
        "siteWeb": { "type": "string" },
        "description": { "type": "string" },
        "logo": { "type": "string" }
      },
      "required": ["id", "name", "memberNo"]
    },
    "user": {
      "title": "User",
      "description": "An administration user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "password": { "type": "string" },
        "dateCreation": { "type": "string" }
      },
      "required": ["id", "nom", "prenom", "email", "role"]
    }
  },
  "firestore": {
    "enterprises": {
      "schema": "enterprise",
      "description": "Collection of member enterprises with cotisations"
    },
    "users": {
      "schema": "user",
      "description": "Collection of system administration users"
    }
  }
}
